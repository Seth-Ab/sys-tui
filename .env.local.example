# Copy this file to .env.local and fill values for your environment.
# .env.local is gitignored.

# mini-agent settings
AGENT_BIND=127.0.0.1:8787
AGENT_TOKEN=replace-with-long-random-token
OLLAMA_PS_URL=http://127.0.0.1:11434/api/ps
WATCH_DIRS=$HOME/Downloads,$HOME/.ollama

# pro-tui settings
AGENT_ENDPOINT=http://core:8787/state
# AGENT_TOKEN should match mini-agent if token auth is enabled.
# AGENT_TOKEN=replace-with-long-random-token
